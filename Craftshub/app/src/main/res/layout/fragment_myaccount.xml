<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/myaccountConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MyaccountFragment" >

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/myaccountToolbar"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/left"
        app:title="My Account"
        app:titleMarginStart="80dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="770dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/dpPicker"
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:layout_marginStart="110dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@android:color/transparent"
                android:contentDescription="Profile Image"
                android:scaleType="center"
                android:src="@drawable/dppicker" />

            <EditText
                android:id="@+id/acnametxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/border"
                android:drawableLeft="@drawable/ac_user"
                android:drawablePadding="12dp"
                android:ems="10"
                android:fontFamily="@font/montserrat_regular"
                android:hint="-------"
                android:inputType="text"
                android:padding="10dp"
                android:textAlignment="viewStart" />

            <EditText
                android:id="@+id/acmobileTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/border"
                android:drawableLeft="@drawable/ac_mobile"
                android:drawablePadding="12dp"
                android:ems="10"
                android:fontFamily="@font/montserrat_regular"
                android:hint="07X-XXXXXXX"
                android:inputType="phone"
                android:padding="10dp"
                android:textAlignment="viewStart" />

            <EditText
                android:id="@+id/acusernameTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/border"
                android:drawableLeft="@drawable/username"
                android:drawablePadding="12dp"
                android:editable="false"
                android:ems="10"
                android:enabled="false"
                android:fontFamily="@font/montserrat_semibold"
                android:hint="user@example"
                android:inputType="text"
                android:padding="10dp"
                android:textAlignment="viewStart" />

            <EditText
                android:id="@+id/acemailTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/border"
                android:drawableLeft="@drawable/ac_email"
                android:drawablePadding="12dp"
                android:editable="false"
                android:ems="10"
                android:enabled="false"
                android:fontFamily="@font/montserrat_semibold"
                android:hint="example@gmail.com"
                android:inputType="textEmailAddress"
                android:padding="10dp"
                android:textAlignment="viewStart"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/acAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/border"
                android:drawableLeft="@drawable/ac_address"
                android:drawablePadding="12dp"
                android:ems="10"
                android:fontFamily="@font/montserrat_regular"
                android:gravity="start|top"
                android:hint="-------"
                android:inputType="textMultiLine"
                android:maxLines="2"
                android:minLines="1"
                android:padding="10dp"
                android:textAlignment="viewStart"
                android:textSize="17sp" />

            <Button
                android:id="@+id/button2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="45dp"
                android:layout_marginTop="36dp"
                android:layout_marginEnd="45dp"
                android:backgroundTint="@color/app_primary"
                android:fontFamily="@font/montserrat_medium"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/save"
                android:textAlignment="center"
                android:textSize="18sp"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>